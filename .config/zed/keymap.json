// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
    {
        "context": "Workspace",
        "bindings": {
            "ctrl-w": null,
            "ctrl-alt-v": "workspace::ToggleVimMode",
            "ctrl-w <": "workspace::IncreaseActiveDockSize",
            "ctrl-w >": "workspace::DecreaseActiveDockSize"
        }
    },
    {
        "context": "Terminal",
        "bindings": {
            "ctrl-w h": "workspace::ActivatePaneLeft",
        }
    },
    {
        "context": "Editor && vim_mode == insert && !menu",
        "bindings": {
            "j k": "vim::NormalBefore",
            "ctrl-q": "zed::Quit",
        }
    },
    {
        "context": "Editor && vim_mode == replace && !menu",
        "bindings": {
            "j k": "vim::NormalBefore",
            "ctrl-q": "zed::Quit",
        }
    },
    {
        "context": "BufferSearchBar && ProjectSearchBar",
        "bindings": {
            "j k": "buffer_search::Dismiss"
        }
    },
    {
        "context": "VimControl && vim_mode == normal && !menu",
        "bindings": {
            "space w": "workspace::Save",
            "space f f":     "file_finder::Toggle",
            "space f g":     "pane::DeploySearch",
            "space h": "pane::ActivatePreviousItem",
            "space l": "pane::ActivateNextItem",
            "space q": "pane::CloseActiveItem",
            "ctrl-alt-down": "editor::AddSelectionBelow",
            "ctrl-alt-up": "editor::AddSelectionAbove",
            "ctrl-q": "zed::Quit",
            "space x x": "diagnostics::Deploy",
            "x": ["workspace::SendKeystrokes", "\" _ x"],
            "d": ["workspace::SendKeystrokes", "\" _ d"],
        }
    },
]
